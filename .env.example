# ─── Copy this file to .env and fill in your real values ─────────────────────
# .env is gitignored. NEVER commit .env with real keys.

# ─── LLM API Keys ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── Vector DB ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# For Qdrant Cloud (https://cloud.qdrant.io): set QDRANT_URL to your cluster URL
# and QDRANT_API_KEY to your cluster's API key. Leave QDRANT_API_KEY empty for local Docker.
QDRANT_API_KEY=

# ─── SQLite (relative to project root, created automatically) ─────────────────
DATABASE_URL=sqlite:///./data/psl.db

# ─── OCR (Windows default Tesseract install path) ─────────────────────────────
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─── File Storage ─────────────────────────────────────────────────────────────
BM25_DIR=./data/bm25
UPLOADS_DIR=./data/uploads

# ─── Demo defaults ────────────────────────────────────────────────────────────
DEFAULT_OPERATOR_ID=op_harvey

# ─── Optional: Langfuse observability (leave blank to disable) ────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
