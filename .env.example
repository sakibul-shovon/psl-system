# ─── Copy this file to .env and fill in real values ──────────────────────
# .env is gitignored; .env.example is committed as a template for others.

# ─── LLM API keys ─────────────────────────────────────────────────────────
# Gemini: https://aistudio.google.com/app/apikey (free tier: 1500 req/day)
GEMINI_API_KEY=your_gemini_key_here

# Groq: https://console.groq.com/keys (free tier)
GROQ_API_KEY=your_groq_key_here

# ─── Local services ───────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# SQLite file (relative to project root)
DATABASE_URL=sqlite:///./data/psl.db

# ─── OCR ──────────────────────────────────────────────────────────────────
# Full path to tesseract.exe — usually this default after UB Mannheim install.
# If you installed elsewhere, change this to match.
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─── File locations ───────────────────────────────────────────────────────
BM25_DIR=./data/bm25
UPLOADS_DIR=./data/uploads

# ─── Demo defaults ────────────────────────────────────────────────────────
# Single hardcoded operator for demo (no auth system)
DEFAULT_OPERATOR_ID=op_harvey

# ─── Optional: Langfuse (Friday stretch goal — leave blank for now) ───────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
